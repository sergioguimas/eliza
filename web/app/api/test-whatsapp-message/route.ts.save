import { NextResponse } from 'next/server';
import { sendWhatsAppMessage } from '@/app/actions/whatsapp-messages'; 

export async function GET() {
  console.log("🛠️ [Sonda de Teste] Iniciando disparo isolado...");

  try {
    const result = await sendWhatsAppMessage({
      phone: "5533999998888", // Coloque seu número real do WhatsApp aqui (com o DDD 33)
      message: "Teste de isolamento de infraestrutura disparado com sucesso!",
      organizationId: "71558534-1aa9-4691-b74c-94a7246dc50a" // O ID que vimos no seu log
    });

    console.log("🛠️ [Sonda de Teste] Resultado:", result);
    return NextResponse.json({ status: "Sonda executada", result });

  } catch (error: any) {
    console.error("🛠️ [Sonda de Teste] Erro fatal capturado:", error);
    return NextResponse.json({ status: "Falha na Sonda", error: error.message || error });
  }
}
